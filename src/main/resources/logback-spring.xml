<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Base log directory -->
    <property name="LOGS_DIR" value="logs" />
    <property name="LOG_FILE" value="${LOGS_DIR}/app.log" />

    <!-- Console Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- Pattern: timestamp | level | [className] | message -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS}  %-5level [%-18.18logger{18}] %msg%n</pattern>
        </encoder>
    </appender>

    <!-- File Appender with daily rotation and max 10MB split -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- Rollover daily and whenever file reaches 10MB -->
            <fileNamePattern>${LOGS_DIR}/app-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- Max size of each log file -->
            <maxFileSize>10MB</maxFileSize>
            <!-- Keep 30 days of history -->
            <maxHistory>30</maxHistory>
            <!-- Total size cap for all log files combined -->
            <totalSizeCap>3GB</totalSizeCap>
        </rollingPolicy>
        
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS}  %-5level [%-18.18logger{18}] %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Environment-specific profile logger configurations -->
    <springProfile name="dev | default">
        <logger name="com.matrimonial" level="DEBUG" />
    </springProfile>

    <springProfile name="prod">
        <logger name="com.matrimonial" level="INFO" />
    </springProfile>

    <logger name="org.springframework.security" level="INFO" />

    <!-- Root logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </root>

</configuration>
